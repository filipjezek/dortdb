{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo",
    "emitDeclarationOnly": true,
    "lib": ["DOM", "ES2024"]
  },
  "include": ["src/**/*.ts"],
  "references": [
    {
      "path": "../../core/tsconfig.lib.json"
    },
    {
      "path": "../../lang-sql/tsconfig.lib.json"
    },
    {
      "path": "../../lang-cypher/tsconfig.lib.json"
    },
    {
      "path": "../../lang-xquery/tsconfig.lib.json"
    }
  ],
  "exclude": [
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx"
  ]
}
