    "@dortdb/lang-xquery": "^1.0.0"
  },
  "dependencies": {
    "@swc/helpers": "^0.5.15",
    "@types/orientjs": "^2.1.6",
    "@types/sql.js": "^1.4.9",
    "@vitest/utils": "^4.1.5",
    "alasql": "^4.17.2",
    "arangojs": "^10.1.1",
    "fast-equals": "^6.0.0",
    "graphology": "^0.26.0",
    "jsdom": "^26.1.0",
    "orientjs": "2.2",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
