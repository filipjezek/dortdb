  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/filipjezek/dortdb.git"
  },
  "private": true,
  "scripts": {
    "unibench": "node --max-old-space-size=30000 --expose-gc dist/index.js -b unibench -d dortdb -T 14400 -q 1 -q 2 -q 3 -q 4 -q 5 -q 6 -q 7 -q 8 -q 9 -q 10",
    "tpch": "node --max-old-space-size=30000 --expose-gc dist/index.js -b tpch -d dortdb -t 4000 -q 1 -q 2 -q 3 -q 4 -q 5 -q 6 -q 7 -q 8 -q 9 -q 10 -q 11 -q 12 -q 13 -q 14 -q 15 -q 16 -q 17 -q 18 -q 19 -q 20 -q 21 -q 22",
    "tpch:sqlite": "node --max-old-space-size=30000 --expose-gc dist/index.js -b tpch -d sqlite -t 4000 -q 1 -q 2 -q 3 -q 4 -q 5 -q 6 -q 7 -q 8 -q 9 -q 10 -q 11 -q 12 -q 13 -q 14 -q 15 -q 16 -q 17 -q 18 -q 19 -q 20 -q 21 -q 22",
    "tpch:alasql": "node --max-old-space-size=30000 --expose-gc dist/index.js -b tpch -d alasql -t 4000 -q 1 -q 2 -q 3 -q 4 -q 5 -q 6 -q 7 -q 8 -q 9 -q 10 -q 11 -q 12 -q 13 -q 14 -q 15 -q 16 -q 17 -q 18 -q 19 -q 20 -q 21 -q 22"
  },
  "author": "dortdb",
  "license": "ISC",
