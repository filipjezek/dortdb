{
  "name": "@dortdb/unibench",
  "type": "module",
  "version": "1.0.0",
  "description": "",
  "exports": {
    ".": "./dist/index.js",
    "./tpch/benchmark": "./dist/tpch/benchmark.js",
    "./tpch/benchmark-sqlite": "./dist/tpch/benchmark-sqlite.js",
    "./tpch/benchmark-alasql": "./dist/tpch/benchmark-alasql.js",
    "./unibench/benchmark": "./dist/unibench/benchmark.js",
    "./unibench/benchmark_arango": "./dist/unibench/benchmark_arango.js",
    "./unibench/benchmark_orient": "./dist/unibench/benchmark_orient.js",
