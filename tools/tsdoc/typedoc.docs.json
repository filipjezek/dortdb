{
  "$schema": "https://typedoc-plugin-markdown.org/schema.json",
  "entryPoints": [
    "../../packages/core",
    "../../packages/lang-sql",
    "../../packages/lang-xquery",
    "../../packages/lang-cypher"
  ],
  "entryPointStrategy": "packages",
  "tsconfig": "./tsconfig.typedoc.json",
  "plugin": ["typedoc-plugin-markdown", "typedoc-docusaurus-theme"],
  "out": "../../packages/docs/docs/api",
  "hideGenerator": true,
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeInternal": true,
  "cleanOutputDir": true,

  "readme": "none",
  "name": "API Reference",
  "sidebar": {
    "typescript": true
  },

  "sort": ["source-order"],
  "groupOrder": ["Classes", "Interfaces", "Functions", "Variables", "*"],
  "parametersFormat": "table",
  "enumMembersFormat": "table"
}
